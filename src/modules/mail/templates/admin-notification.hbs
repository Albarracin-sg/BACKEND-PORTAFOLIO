<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nuevo mensaje en tu portafolio</title>
  <style>
    @media only screen and (max-width: 600px) {
      .container { width: 100% !important; padding: 0 12px !important; }
      .content   { padding: 24px 18px !important; }
      .title     { font-size: 20px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#0a0a0a; font-family:'Segoe UI',Arial,sans-serif; color:#fafafa;">

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
    style="background-color:#0a0a0a; padding:40px 16px;">
    <tr>
      <td align="center">

        <table class="container" role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width:560px; background-color:#18181b; border:1px solid #27272a; border-radius:20px; overflow:hidden;">

          <!-- Top accent -->
          <tr>
            <td style="height:3px; background:linear-gradient(90deg,#7c3aed,#a78bfa);"></td>
          </tr>

          <!-- Header -->
          <tr>
            <td style="padding:22px 30px 18px 30px; border-bottom:1px solid #27272a;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <img src="cid:logo" alt="Logo" style="height:80px; width:auto; display:block;" />
                  </td>
                  <td align="right">
                    <span style="font-size:10px; font-weight:700; letter-spacing:1.8px; text-transform:uppercase;
                                 color:#a78bfa; background:#27272a; border:1px solid #3f3f46;
                                 border-radius:100px; padding:4px 12px;">
                      Nuevo lead
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Alert banner -->
          <tr>
            <td style="padding:20px 30px 0 30px;">
              <div style="background:#27272a; border:1px solid #3f3f46; border-radius:12px;
                          padding:14px 18px; display:flex; align-items:center;">
                <span style="font-size:13px; color:#a1a1aa; line-height:1.5;">
                  🔔 <strong style="color:#fafafa;">Alguien te escribió desde el portafolio.</strong>
                  Por favor respóndele pronto — la primera respuesta marca la diferencia.
                </span>
              </div>
            </td>
          </tr>

          <!-- Hero -->
          <tr>
            <td class="content" style="padding:24px 30px 16px 30px;">

              <div style="font-size:11px; font-weight:700; text-transform:uppercase;
                          letter-spacing:2px; color:#a78bfa; margin-bottom:8px;">
                Nuevo contacto
              </div>

              <h1 class="title"
                style="margin:0 0 6px 0; font-size:22px; font-weight:800;
                       line-height:1.3; color:#fafafa; letter-spacing:-0.3px;">
                {{name}} quiere hablar contigo.
              </h1>

              <p style="margin:0; font-size:13px; color:#71717a;">
                Recibido desde el formulario de contacto del portafolio.
              </p>

            </td>
          </tr>

          <!-- Data card -->
          <tr>
            <td style="padding:0 30px 16px 30px;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0"
                style="background:#0a0a0a; border:1px solid #27272a; border-radius:12px; overflow:hidden;">

                <tr style="border-bottom:1px solid #27272a;">
                  <td style="padding:12px 16px; width:28%; font-size:11px; font-weight:700;
                             text-transform:uppercase; letter-spacing:1px; color:#52525b;
                             border-right:1px solid #27272a; white-space:nowrap;">
                    Nombre
                  </td>
                  <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#fafafa;">
                    {{name}}
                  </td>
                </tr>

                <tr style="border-bottom:1px solid #27272a;">
                  <td style="padding:12px 16px; font-size:11px; font-weight:700;
                             text-transform:uppercase; letter-spacing:1px; color:#52525b;
                             border-right:1px solid #27272a;">
                    Correo
                  </td>
                  <td style="padding:12px 16px; font-size:13px;">
                    <a href="mailto:{{email}}" style="color:#a78bfa; text-decoration:none; font-weight:600;">{{email}}</a>
                  </td>
                </tr>

                {{#if company}}
                <tr style="border-bottom:1px solid #27272a;">
                  <td style="padding:12px 16px; font-size:11px; font-weight:700;
                             text-transform:uppercase; letter-spacing:1px; color:#52525b;
                             border-right:1px solid #27272a;">
                    Empresa
                  </td>
                  <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#fafafa;">
                    {{company}}
                  </td>
                </tr>
                {{/if}}

                <tr>
                  <td style="padding:12px 16px; font-size:11px; font-weight:700;
                             text-transform:uppercase; letter-spacing:1px; color:#52525b;
                             border-right:1px solid #27272a; vertical-align:top;">
                    Mensaje
                  </td>
                  <td style="padding:12px 16px;">
                    <div style="font-size:13px; line-height:1.7; color:#a1a1aa;
                                border-left:2px solid #7c3aed; padding-left:12px;">
                      {{message}}
                    </div>
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <!-- CTA reply -->
          <tr>
            <td style="padding:0 30px 30px 30px;">
              <table cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                  <td style="border-radius:10px; background:#7c3aed; text-align:center;">
                    <a href="mailto:{{email}}"
                      style="display:block; padding:12px 24px; font-size:13px;
                             font-weight:700; color:#fafafa; text-decoration:none;
                             border-radius:10px; letter-spacing:0.2px;">
                      Responder a {{name}} →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:14px 30px 20px 30px; border-top:1px solid #27272a;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:11px; color:#3f3f46;">
                    Juan Albarracín · Portafolio
                  </td>
                  <td align="right" style="font-size:11px; color:#3f3f46;">
                    Sistema automático
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>