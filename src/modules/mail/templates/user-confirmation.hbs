<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gracias por escribirme</title>
  <style>
    @media only screen and (max-width: 600px) {
      .container { width: 100% !important; padding: 0 12px !important; }
      .content   { padding: 28px 20px !important; }
      .title     { font-size: 22px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#0a0a0a; font-family:'Segoe UI',Arial,sans-serif; color:#fafafa;">

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
    style="background-color:#0a0a0a; padding:40px 16px;">
    <tr>
      <td align="center">

        <table class="container" role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"
          style="max-width:560px; background-color:#18181b; border:1px solid #27272a; border-radius:20px; overflow:hidden;">

          <!-- Top accent -->
          <tr>
            <td style="height:3px; background:linear-gradient(90deg,#7c3aed,#a78bfa);"></td>
          </tr>

          <!-- Header -->
          <tr>
            <td style="padding:22px 30px 18px 30px; border-bottom:1px solid #27272a;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td>
                    <img src="cid:logo" alt="Logo" style="height:80px; width:auto; display:block;" />
                  </td>
                  <td align="right">
                    <span style="font-size:10px; font-weight:700; letter-spacing:1.8px; text-transform:uppercase;
                                 color:#a78bfa; background:#27272a; border:1px solid #3f3f46;
                                 border-radius:100px; padding:4px 12px;">
                      Recibido
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Hero -->
          <tr>
            <td class="content" style="padding:36px 30px 10px 30px; text-align:center;">

              <div style="width:48px; height:48px; background:#27272a; border:1px solid #3f3f46;
                          border-radius:12px; margin:0 auto 22px auto; font-size:20px;
                          line-height:48px; text-align:center;">
                ✉️
              </div>

              <div style="font-size:11px; font-weight:700; text-transform:uppercase;
                          letter-spacing:2px; color:#a78bfa; margin-bottom:10px;">
                ¡Hola, {{name}}!
              </div>

              <h1 class="title"
                style="margin:0 0 14px 0; font-size:25px; font-weight:800;
                       line-height:1.3; color:#fafafa; letter-spacing:-0.3px;">
                Tu mensaje llegó perfecto.
              </h1>

              <p style="margin:0 auto; font-size:14px; line-height:1.75; color:#a1a1aa; max-width:400px;">
                Gracias por escribirme. Ya lo tengo en el radar y te responderé pronto
                a <a href="mailto:{{email}}" style="color:#a78bfa; text-decoration:none; font-weight:600;">{{email}}</a>.
                Mientras tanto, te invito a ver en qué estoy trabajando.
              </p>

              <!-- CTA -->
              <table cellspacing="0" cellpadding="0" border="0" style="margin:26px auto 0 auto;">
                <tr>
                  <td style="border-radius:10px; background:#7c3aed;">
                    <a href="https://portafolio-frontend-three.vercel.app/projects"
                      style="display:inline-block; padding:11px 24px; font-size:13px;
                             font-weight:700; color:#fafafa; text-decoration:none;
                             border-radius:10px; letter-spacing:0.2px;">
                      Ver proyectos →
                    </a>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Message preview -->
          <tr>
            <td style="padding:24px 30px 30px 30px;">
              <div style="background:#0a0a0a; border:1px solid #27272a; border-radius:12px; padding:16px 18px;">
                <div style="font-size:10px; font-weight:700; text-transform:uppercase;
                            letter-spacing:1.5px; color:#52525b; margin-bottom:10px;">
                  Lo que me enviaste
                </div>
                <div style="font-size:13px; line-height:1.7; color:#71717a;
                            border-left:2px solid #7c3aed; padding-left:12px; font-style:italic;">
                  {{message}}
                </div>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:14px 30px 20px 30px; border-top:1px solid #27272a;">
              <table width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-size:11px; color:#3f3f46;">
                    Juan Albarracín · Bogotá, Colombia
                  </td>
                  <td align="right" style="font-size:11px; color:#3f3f46;">
                    Mensaje automático
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>