generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Page {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sections    Section[]
}

model Section {
  id        String      @id @default(cuid())
  pageId    String
  type      SectionType
  order     Int
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  page      Page        @relation(fields: [pageId], references: [id])
}

model Project {
  id           String              @id @default(cuid())
  title        String
  description  Json
  problem      Json
  challenge    Json
  solution     Json
  imageUrl     String
  githubUrl    String
  liveUrl      String?
  category     String
  status       String
  featured     Boolean             @default(false)
  stars        Int                 @default(0)
  forks        Int                 @default(0)
  views        Int                 @default(0)
  date         DateTime
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  technologies ProjectTechnology[]
}

model Technology {
  id       String              @id @default(cuid())
  name     String              @unique
  projects ProjectTechnology[]
}

model ProjectTechnology {
  projectId    String
  technologyId String
  project      Project    @relation(fields: [projectId], references: [id])
  technology   Technology @relation(fields: [technologyId], references: [id])

  @@id([projectId, technologyId])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  status    MessageStatus @default(RECEIVED)
  createdAt DateTime      @default(now())
  company   String?
  subject   String
}

model GitHubRepoCache {
  id        String   @id @default(cuid())
  owner     String
  name      String
  data      Json
  etag      String?
  fetchedAt DateTime
  ttlSec    Int

  @@unique([owner, name])
}

model GitHubSummaryCache {
  id        String   @id @default(cuid())
  data      Json
  etag      String?
  fetchedAt DateTime
  ttlSec    Int
}

model Persona {
  id        String     @id @default(cuid())
  name      String
  prompt    String
  model     String
  settings  Json
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  threads   AIThread[]
}

model AIThread {
  id             String      @id @default(cuid())
  personaId      String
  title          String?
  isAnalyzed     Boolean     @default(false)
  analysisResult String?
  createdAt      DateTime    @default(now())
  messages       AIMessage[]
  persona        Persona     @relation(fields: [personaId], references: [id])

  @@index([isAnalyzed])
}

model AIMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime @default(now())
  thread    AIThread @relation(fields: [threadId], references: [id])
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
}

model RequestLog {
  id           String   @id @default(cuid())
  method       String
  path         String
  status       Int
  responseTime Int
  ip           String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([timestamp])
  @@index([path, method])
  @@index([timestamp, path, method])
}

model ServerMetric {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  VIEWER
}

enum SectionType {
  HERO
  ABOUT
  PROJECTS
  CONTACT
  STATS
}

enum MessageStatus {
  RECEIVED
  SENT
  FAILED
}
