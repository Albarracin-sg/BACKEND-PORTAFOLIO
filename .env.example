# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"

# Auth
JWT_SECRET="your-jwt-secret-here"

# Server
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# GitHub
GITHUB_USERNAME="your-github-username"
GITHUB_TOKEN="your-github-token"
GITHUB_CACHE_TTL_MINUTES=30

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-admin-password"

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-without-spaces
MAIL_FROM=your-email@gmail.com

# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REFRESH_TOKEN=your-spotify-refresh-token
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8787/callback

# HuggingFace AI Bot
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL=microsoft/Phi-3-mini-128k-instruct
HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models
HUGGINGFACE_MAX_TOKENS=512
HUGGINGFACE_TIMEOUT_MS=30000